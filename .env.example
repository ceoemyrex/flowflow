# Copy this to .env on the VM and fill in real values.
# .env is gitignored 

DOCKERHUB_USER=your-dockerhub-username

DB_USER=formflow
DB_PASSWORD=changeme-generate-a-real-secret
DB_NAME=formflow

JWT_SECRET=changeme-generate-a-real-secret

# These two are set automatically by the CI deploy job, not by hand:
BACKEND_TAG=sha-local
FRONTEND_TAG=sha-local